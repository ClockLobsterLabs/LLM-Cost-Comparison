# Copy this file to .env and fill in real values. .env is gitignored.
# Do not commit secrets.

# Required for API calls
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override defaults
LLMCC_OUTPUT_DIR=data
LLMCC_DATABASE_URL=sqlite:///data/llm_cost_comparison.db
LLMCC_REFERER=https://github.com/ClockLobsterLabs/LLM-Cost-Comparison
LLMCC_DEFAULT_TIMEOUT=120
LLMCC_DEFAULT_RETRIES=3
