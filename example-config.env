# =============================================================================
# LLM Cost Comparison — User Configuration Template
# =============================================================================
# Copy this file to experiment-config.ps1 (gitignored) and fill in your keys.
# The experiment-runner.ps1 script dot-sources experiment-config.ps1 at startup.
#
# All values shown are EXAMPLES — replace with your own credentials.
# =============================================================================

# --- Required: API keys ------------------------------------------------

# OpenRouter API key for running measurements.
# Get yours at: https://openrouter.ai/keys
$script:OPENROUTER_API_KEY = "REPLACE-WITH-YOUR-OPENROUTER-API-KEY"

# (Optional) Alternative keys for cross-provider comparisons.
# Different OpenRouter keys may route to different workspaces with
# different provider allowlists, producing different E values.
# $script:OPENROUTER_VERI_KEY = "sk-or-v1-..."
# $script:OPENROUTER_SETUP_KEY = "sk-or-v1-..."

# (Optional) Direct provider keys for provider-level measurements.
# $script:ANTHROPIC_API_KEY = "sk-ant-..."
# $script:OPENAI_API_KEY = "sk-proj-..."
# $script:GOOGLE_API_KEY = "AIza..."
# $script:AWS_ACCESS_KEY_ID = "AKIA..."
# $script:AWS_SECRET_ACCESS_KEY = "..."

# --- Optional: Output paths --------------------------------------------

# Where raw experiment results are written (default: data/ folder)
# $script:OUTPUT_DIR = "$PSScriptRoot/data"

# Log file for experiment progress
# $script:LOG_FILE = "$PSScriptRoot/experiment.log"

# --- Optional: Model list override -------------------------------------
# By default experiment-runner.ps1 tests all 23 models in its $Models array.
# To test a custom subset, uncomment and modify:
# $script:CUSTOM_MODELS = @(
#     @{ id = "openai/gpt-5.4-nano";  name = "GPT-5.4 Nano";  family = "openai" }
#     @{ id = "anthropic/claude-sonnet-5"; name = "Claude Sonnet 5"; family = "anthropic" }
# )

# =============================================================================
# Configuration Notes
# =============================================================================
#
# 1. max_tokens=20 is the standardized value — it minimizes output cost while
#    still returning usage.prompt_tokens reliably. Most models respect this.
#    Grok 4.5 is the known exception (ignores max_tokens, generates 461-1161
#    tokens regardless).
#
# 2. temperature=0 ensures deterministic tokenization — the prompt_tokens field
#    is deterministic regardless of temperature, but zero removes variance.
#
# 3. Different API keys route to different OpenRouter workspaces with
#    different provider allowlists. If a model is guardrail-blocked on your
#    key, try a different key or check OpenRouter's Model Access settings.
#
# 4. Total cost for a full 23-model × 3-sample run is ~$0.20 at current
#    OpenRouter pricing. Testing one model (3 calls) costs ~$0.01.
